# ── DB ──────────────────────────────────────────────────
DATABASE_URL=sqlite:///./stockplatform.db
SECRET_KEY=your-secret-key-change-this

# ── 한국투자증권 KIS API ─────────────────────────────────
# https://apiportal.koreainvestment.com 에서 발급
KIS_APP_KEY=발급받은_APP_KEY
KIS_APP_SECRET=발급받은_APP_SECRET
KIS_ACCOUNT_NO=계좌번호-숫자만
KIS_IS_REAL=false   # 모의투자: false, 실거래: true

# ── Finnhub API (미국 주식 실시간) ──────────────────────
# https://finnhub.io 무료 가입 후 발급 (60 req/min 무료)
FINNHUB_API_KEY=발급받은_FINNHUB_KEY

# ── OpenDART API (국내 공시/재무제표) ───────────────────
# https://opendart.fss.or.kr 무료 회원가입 후 발급
DART_API_KEY=발급받은_DART_KEY

# ── FMP API (해외 재무제표) ─────────────────────────────
# https://financialmodelingprep.com 무료 가입 후 발급 (250 req/day 무료)
FMP_API_KEY=발급받은_FMP_KEY

# ── Anthropic API (뉴스 AI 요약) ────────────────────────
# https://console.anthropic.com 에서 발급. 설정하지 않으면 AI 요약 기능은 비활성화됨
ANTHROPIC_API_KEY=발급받은_ANTHROPIC_KEY
